# ═════════════════════════════════════════════════════════════════════════════
# EduAI Environment Variables Template
# Copy this to .env and fill in your values (never commit actual .env)
# For Render deployment, set these in Dashboard > Environment
# ═════════════════════════════════════════════════════════════════════════════

# ─── Django Settings ────────────────────────────────────────────────────────
# For Render production, use: config.settings.production
# For local development, use: config.settings.development
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-use-a-long-random-string-in-production
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.co.ke,www.yourdomain.co.ke

# ─── Database Configuration ───────────────────────────────────────────────────
# For LOCAL DEVELOPMENT (MySQL):
#DB_ENGINE=django.db.backends.mysql
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_NAME=Mentify
#DB_USER=root
#DB_PASSWORD=your_mysql_password

# For RENDER PRODUCTION (PostgreSQL via DATABASE_URL):
# Render automatically provides DATABASE_URL in production.
# DO NOT SET DB_* vars below on Render — comment them out and use DATABASE_URL instead.
# Uncomment below for local PostgreSQL testing:
#DATABASE_URL=postgresql://postgres:password@localhost:5432/mentify_db

# MySQL specific (ignored on Render)
DB_SSL=false

# ─── Email Configuration (Gmail SMTP) ───────────────────────────────────────
# Generate App Password in Google Account > Security > App passwords
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_16chars
DEFAULT_FROM_EMAIL=noreply@yourdomain.co.ke

# ─── Paystack Payment Gateway (Kenya) ──────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
PAYSTACK_CALLBACK_URL=https://yourdomain.co.ke/payments/callback/
PAYSTACK_CURRENCY=KES

# ─── GitHub (for PDF / Resource Uploads) ──────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-username/MENTIFY-uploads
GITHUB_BRANCH=main
GITHUB_UPLOAD_DIR=uploads

# ─── Bunny Stream (Video CDN) ─────────────────────────────────────────────
BUNNY_STREAM_LIBRARY_ID=123456
BUNNY_STREAM_API_KEY=your-bunny-api-key
BUNNY_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net
BUNNY_TOKEN_AUTH_KEY=your-token-auth-key-if-enabled

# ─── Platform Configuration ────────────────────────────────────────────────
PLATFORM_NAME=Mentify
# For local dev, use http://127.0.0.1:8000
# For Render, use https://your-app.onrender.com (provided by Render)
BASE_URL=http://127.0.0.1:8000

# ─── Google OAuth (Optional) ───────────────────────────────────────────────
# Set up at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/accounts/google/callback/

# ─── Admin Email Whitelist (Comma-separated) ──────────────────────────────
# Anyone with these emails will be auto-promoted to admin role on first login
ADMIN_EMAILS=admin@yourdomain.co.ke,owner@yourdomain.co.ke

